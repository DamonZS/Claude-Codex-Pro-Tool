{
  "format_version": 1,
  "id": "cyber-changan",
  "name": "赛博长安",
  "version": "0.1.0-ccp.1",
  "author": "Theme Studio for Codex contributors",
  "description": "Cyber Changan adapted for the CCP Codex Theme Loader.",
